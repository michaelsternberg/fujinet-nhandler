   266 				;;; DEVICE HANDLER TABLE ;;;;;;;;;;;;;;;;;;;;;;;;;
   267
   268 22FA 84 23		DEVHDL:	.WORD	OPEN-1
   269 22FC C1 23			.WORD	CLOSE-1
   270 22FE E5 23			.WORD	GET-1
   271 2300 35 24			.WORD	PUT-1
   272 2302 4D 24			.WORD	STATUS-1
   273 2304 7A 24			.WORD	SPECIAL-1
   274 					
   275 				;;; HANDLER RUNAD HERE ;;;;;;;;;;;;;;;;;;;;;;;;;;;
   276 					
   277 2306 A5 0C		START:	LDA	DOSINI
   278 2308 8D 02 22			STA	RESET+1
   279 230B A5 0D			LDA	DOSINI+1
   280 230D 8D 03 22			STA	RESET+2
   281 2310 A9 01			LDA	#<RESET
   282 2312 85 0C			STA	DOSINI
   283 2314 A9 22			LDA	#>RESET
   284 2316 85 0D			STA	DOSINI+1
   285 2318 A9 C9			LDA	#<HANDLEREND
   286 231A 8D E7 02			STA	MEMLO
   287 231D 8D 05 22			STA	RESET+4
   288 2320 A9 26			LDA	#>HANDLEREND
   289 2322 8D E8 02			STA	MEMLO+1
   290 2325 8D 0A 22			STA	RESET+9
   291 2328 20 AB 22			JSR	CLALL		; Close all
   292 					
   293 				;;; Insert Handler entry into HATABS ;;;;;;;;;;;
   294
   295 232B A0 00		IHTBS:	LDY	#$00		; Start at beginning of HATABS
   296 232D B9 1A 03		IH1:	LDA	HATABS,Y
   297 2330 F0 0B			BEQ	HFND		; Did we find a blank ($00) entry?
   298 2332 C9 4E			CMP	#'N'		; or did we find our existing 'N' entry?
   299 2334 F0 07			BEQ	HFND		; If so, insert our entry here.
   300 2336 C8				INY			; Otherwise, scoot forward to next entry.
   301 2337 C8				INY			
   302 2338 C8				INY
   303 2339 C0 21			CPY	#11*3		; Are we at the end of the table?
   304 233B 90 F0			BCC	IH1		; Check again.
   305
   306 					;; We found a slot, insert it in.
   307
   308 233D A9 4E		HFND:	LDA	#'N'		; We are the N: device
   309 233F 99 1A 03			STA	HATABS,Y	; first byte in our entry
   310 2342 A9 FA			LDA	#<DEVHDL	; Get address of our handler table
   311 2344 99 1B 03			STA	HATABS+1,Y	; and put it in Hatabs
   312 2347 A9 22			LDA	#>DEVHDL
   313 2349 99 1C 03			STA	HATABS+2,Y
   314 					
   315 					;; And vector in PROCEED.
   316
   317 234C A9 15		VPRCD:	LDA	#<INTR		; Get Addr of interrupt handler
   318 234E 8D 02 02			STA	VPRCED		; Store it in PROCEED vector
   319 2351 A9 22			LDA	#>INTR
   320 2353 8D 03 02			STA	VPRCED+1
   321 					
   322 					;; We're done, back to DOS.
   323
   324 2356 60				RTS
   325
   326 				;;; INDICATE SUCCESS ;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   327
   328 2357 A0 01		SUCC:	LDY	#$01 		; Indicate success
   329 2359 60				RTS			; Back to caller.
   330
   331 				;;; CLEAR BUFFERS FOR UNIT X ;;;;;;;;;;;;;;;;;;;;
   332 					
   333 235A A9 00		CLRBUF:	LDA	#$00
   334 235C 9D AC 25			STA	RLEN,X
   335 235F 9D B4 25			STA	TOFF,X
   336 2362 9D B0 25			STA	ROFF,X
   337 2365 9D B9 25			STA	DVS2,X
   338 2368 9D BD 25			STA	DVS3,X
   339 236B 60				RTS
   340 					
   341 				;;; COPY TABLE TO DCB AND DO SIO CALL ;;;;;;;;;;;
   342
   343 236C 8D 75 23		DOSIOV: STA	DODCBL+1	; Set source address
   344 236F 8C 76 23			STY	DODCBL+2
   345 2372 A0 0C			LDY	#$0C		; 12 bytes
   346 2374 B9 FF FF		DODCBL	LDA	$FFFF,Y		; Changed above.
   347 2377 99 00 03			STA	DCB,Y		; To DCB table
   348 237A 88				DEY			; Count down
   349 237B 10 F7			BPL	DODCBL		; Until done
   350
   351 237D			SIOVDST:	
   352 237D 20 59 E4			JSR	SIOV		; Call SIOV
   353 2380 AC 03 03			LDY	DSTATS		; Get STATUS in Y
   354 2383 98				TYA			; Copy it into A
   355 2384 60				RTS			  ; Done
   356 					
   357 				;;; OPEN ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   358
   359 					;; Fill in the OPEN table
   360 					
   361 2385 20 1C 22		OPEN:   JSR	GDIDX		; Set IOCB OFFSET TO UNIT #
   362 2388 20 5A 23			JSR	CLRBUF		; Clear Buffers
   363 238B A5 21			LDA	ZICDNO		; GET Desired unit #
   364 238D 8D B7 23			STA	OPNDCB+1	; Store in open table
   365 2390 A5 24			LDA	ZICBAL		; Get desired buffer LO
   366 2392 8D BA 23			STA	OPNDCB+4	  ; Store in open table
   367 2395 A5 25			LDA	ZICBAH		; Get desired buffer HI
   368 2397 8D BB 23			STA	OPNDCB+5	; Store in open table
   369 239A A5 2A			LDA	ZICAX1		; Get requested Aux1
   370 239C 8D C0 23			STA	OPNDCB+10	; Store in open table
   371 239F A5 2B			LDA	ZICAX2		; Get requested Aux2
   372 23A1 8D C1 23			STA	OPNDCB+11	; Store in open table
   373
   374 					;; Do the SIOV call
   375 					
   376 23A4 A9 B6			LDA	#<OPNDCB
   377 23A6 A0 23			LDY	#>OPNDCB
   378 23A8 20 6C 23			JSR	DOSIOV
   379
   380 					;; Return DSTATS in Y, unless 144, then get ext err.
   381
   382 23AB C0 90			CPY	#144		; Did we get an ERROR- 144?
   383 23AD D0 06			BNE	OPDONE		; Nope, keep DSTATS in Y
   384
   385 					;; We got a 144, get error from STATUS call
   386 23AF 20 20 22			JSR	POLL		; Do Status poll
   387 23B2 AC ED 02			LDY	DVSTAT+3	; Get error code
   388
   389 23B5 60			OPDONE:	RTS
   390
   391 					;; OPEN DCB TABLE
   392
   393 23B6			OPNDCB:
   394 23B6 71				.BYTE      DEVIDN  	; DDEVIC
   395 23B7 FF				.BYTE      $FF     	; DUNIT
   396 23B8 4F				.BYTE      'O'     	; DCOMND
   397 23B9 80				.BYTE      DSWRIT     	; DSTATS
   398 23BA FF				.BYTE      $FF     	; DBUFL
   399 23BB FF				.BYTE      $FF     	; DBUFH
   400 23BC 1F				.BYTE      $1F     	; DTIMLO
   401 23BD 00				.BYTE      $00     	; DRESVD
   402 23BE 00				.BYTE      $00     	; DBYTL
   403 23BF 01				.BYTE      $01     	; DBYTH
   404 23C0 FF				.BYTE      $FF     	; DAUX1
   405 23C1 FF				.BYTE      $FF     	; DAUX2
   406
   407 				;;; CLOSE ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   408
   409 23C2 20 5B 22		CLOSE:	JSR	DIPRCD		; Disable PROCEED
   410 23C5 20 64 22			JSR	FLUSH		; do PUT flush if needed.
   411 23C8 20 5A 23			JSR	CLRBUF		; Clear buffer pointers
   412 23CB A5 21			LDA	ZICDNO		; Unit #
   413 23CD 8D DB 23			STA	CLODCB+1	; Put into table
   414 23D0 A9 DA			LDA	#<CLODCB	; Close DCB table
   415 23D2 A0 23			LDY	#>CLODCB
   416 23D4 20 6C 23			JSR	DOSIOV		; Do SIOV
   417 23D7 4C 57 23			JMP	SUCC		; Always return success
   418
   419 23DA 71			CLODCB .BYTE	DEVIDN		; DDEVIC
   420 23DB FF			       .BYTE	$FF		; DUNIT
   421 23DC 43			       .BYTE	'C'		; DCOMND
   422 23DD 00			       .BYTE	$00		; DSTATS
   423 23DE 00			       .BYTE	$00		; DBUFL
   424 23DF 00			       .BYTE	$00		; DBUFH
   425 23E0 1F			       .BYTE	$1F		; DTIMLO
   426 23E1 00			       .BYTE	$00		; DRESVD
   427 23E2 00			       .BYTE	$00		; DBYTL
   428 23E3 00			       .BYTE	$00		; DBYTH
   429 23E4 00			       .BYTE	$00		; DAUX1
   430 23E5 00			       .BYTE	$00		; DAUX2
   431
   432 				;;; GET ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   433
   434 23E6 20 1C 22		GET:	JSR	GDIDX		; Unit into X
   435 23E9 BD AC 25			LDA	RLEN,X		; Get current RX len from last STATUS
   436 23EC D0 29			BNE	GETDRN		; If RLEN > 0 then drain.
   437
   438 					;; Otherwise, we wai  t for something to happen.
   439
   440 23EE 20 52 22		GETWAI:	JSR	ENPRCD		; Enable Proceed
   441 23F1 AD AB 25			LDA	TRIP		; Did trip change?
   442 23F4 F0 F8			BEQ	GETWAI		; Nope, not yet...
   443
   444 					;; Something happened, try to poll for data.
   445
   446 23F6 20 20 22			JSR	POLL		; Do Status Poll
   447 23F9 20 39 22			JSR	SVSTAT		; Save Status
   448 23FC 20 C1 22			JSR	READ		; Do read
   449
   450 					;; If RLEN=0 then determine if error.
   451
   452 23FF AD EA 02			LDA	DVSTAT		; Get RLEN Again
   453 2402 D0 13			BNE	GETDRN		; If RLEN > 1, then drain.
   454 2404 AC ED 02			LDY	DVSTAT+3	; Get ext err
   455 2407 C0 88			CPY	#136		; EOF?
   456 2409 F0 2A			BEQ	GETDNE		; Yes, return it.
   457 240B AC 03 03			LDY	DSTATS		; Else, get DSTATS from status/read.
   458 240E C0 90			CPY	#144		; is it 144?
   459 2410 D0 23			BNE	GETDNE		; Nope, simply return it in Y, done.
   460 2412 AC ED 02			LDY	DVSTAT+3	; Get Extended error
   461 2415 D0 1E			BNE	GETDNE		; Done.
   462
   463 					;; Drain
   464 					
   465 2417 20 5B 22		GETDRN:	JSR	DIPRCD		; Disable PROCEED
   466 241A 20 1C 22			JSR	GDIDX		; Get Unit into X again
   467 241D DE AC 25			DEC	RLEN,X		; Decrement length
   468 2420 BC B0 25			LDY	ROFF,X		; Get Current Offset into X
   469 2423 B9 C1 25			LDA	RBUF,Y		; Get next character
   470 2426 FE B0 25			INC	ROFF,X		; Increment cursor
   471 2429 A8				TAY			; Store in Y for a moment
   472
   473 					;; If RX buffer empty, turn off trip.
   474
   475 242A BD AC 25			LDA	RLEN,X		; Get RLEN
   476 242D D0 03			BNE	GETDN2		; some left, just go done with success
   477 242F 8D AB 25			STA	TRIP		; Otherwise store 0 into trip
   478 					
   479 2432 98			GETDN2:	TYA			; Bring back char into A
   480 2433 A0 01			LDY	#$01		; 
   481 2435 60			GETDNE:	RTS
   482 					
   483 				;;; PUT ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   484
   485 2436 20 1C 22		PUT:	JSR	GDIDX		; Get Unit # into X
   486 2439 BC B4 25			LDY	TOFF,X		; Get TX cursor
   487 243C 99 41 26			STA	TBUF,Y		; Put char into buffer ptd by cursor
   488
   489 243F FE B4 25			INC	TOFF,X		; Increment TX cursor
   490
   491 					;; Do a FLUSH if EOL or buffer full
   492
   493 2442 C9 9B			CMP	#EOL		; EOL?
   494 2444 F0 04			BEQ	PFLUSH		; Do flush
   495 2446 C0 7F			CPY	#$7F		; At end of buffer?
   496 2448 D0 03			BNE	PUTDON		; Nope, done.
   497 244A 20 64 22		PFLUSH:	JSR	FLUSH		; Do Flush.
   498 244D 60			PUTDON:	RTS			; We're done.
   499 					
   500 				;;; STATUS ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   501
   502 244E 20 52 22		STATUS:	JSR	ENPRCD		; Enable PROCEED.
   503
   504 					;; Return cached value if we still have data in RX
   505
   506 2451 20 1C 22			JSR	GDIDX		; Unit into X
   507 2454 BD AC 25			LDA	RLEN,X		; Get RX len
   508 2457 D0 0E			BNE	STRETC		; Return cached value if RLEN > 0
   509
   510 2459 AD AB 25			LDA	TRIP		; Get TRIP?
   511 245C F0 09			BEQ	STRETC		; No trip? Return cached.
   512
   513 245E 20 20 22			JSR	POLL		; RLEN = 0, do poll.
   514 2461 20 39 22			JSR	SVSTAT		; Save DVSTAT values
   515 2464 20 C1 22			JSR	READ		; Do read.
   516 					
   517 2467 BD AC 25		STRETC:	LDA	RLEN,X		; Get Saved DVSTAT+0 val
   518 246A 8D EA 02			STA	DVSTAT		; Store into DVSTAT
   519 246D BD B9 25			LDA	DVS2,X		; Get Saved DVSTAT+2 val
   520 2470 8D EC 02			STA	DVSTAT+2	; Store
   521 2473 BD BD 25			LDA	DVS3,X		; Get Saved DVSTAT+3 val
   522 2476 8D ED 02			STA	DVSTAT+3
   523 2479 A8				TAY			; copy it into Y for error output.
   524 					
   525 247A 60				RTS			; Done.	
   526 					
   527 				;;; SPECIAL ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   528
   529 247B			SPECIAL:
   530 					
   531 					;; Clear Trip
   532
   533 247B A9 00			LDA	#$00
   534 247D 8D AB 25			STA	TRIP
   535
   536 					;; Handle Local Commands
   537
   538 2480 A5 22			LDA	ZICCOM
   539 2482 C9 0F			CMP	#$0F		; 15 = FLUSH
   540 2484 D0 08			BNE	SPB		; No. Handle protocol commands
   541 2486 20 64 22			JSR	FLUSH		; Yes. Do flush.
   542 2489 A0 01			LDY	#$01		; Flush always successful
   543 248B 4C 08 25			JMP	SPCDNE		; We're done.
   544
   545 					;; Handle Binary Load
   546
   547 248E C9 28		SPB:	CMP	#40		; 40 = BINARY LOAD
   548 2490 D0 03			BNE	SPQ		; No.
   549 2492 4C 1C 25			JMP 	BLOAD		; Yes. Attempt binary load
   550
   551 					;; Handle Protocol commands, do INQDS Query
   552
   553 2495 A9 FF		SPQ:	LDA	#$FF		; Set INQDS
   554 2497 8D 0B 25			STA	SPEDCB+2		; To ICCOM
   555 249A A5 21			LDA	ZICDNO		; Get Unit #
   556 249C 8D 0A 25			STA	SPEDCB+1	; Store in table
   557 249F A5 22			LDA	ZICCOM		; Get Command
   558 24A1 8D 13 25			STA	SPEDCB+10	; Put in AUX1 for query
   559 24A4 A9 01			LDA	#$01		; 1 byte
   560 24A6 8D 11 25			STA	SPEDCB+8	;
   561 24A9 A9 00			LDA	#$00		;
   562 24AB 8D 12 25			STA	SPEDCB+9	;
   563 24AE A9 09			LDA	#<SPEDCB	; Set up SPECIAL DCB TABLE
   564 24B0 A0 25			LDY	#>SPEDCB	;
   565 24B2 20 6C 23			JSR	DOSIOV		; Do Query
   566 24B5 AC 03 03			LDY	DSTATS		; Get DSTATS
   567 24B8 30 4E			BMI	SPCDNE		; SIO error, return in Y. There is no ext err.
   568
   569 					;; We got a query, if it's $FF, return unimplemented.
   570 24BA AD B8 25			LDA	INQDS		; Get the Returned DSTATS value from inquiry
   571 24BD C9 FF			CMP	#$FF		; Is it $FF ?
   572 24BF D0 05			BNE	SPDO		; Nope, let's do it.
   573 24C1 A0 92			LDY	#146		; ERROR- 146  Unimplemented Command
   574 24C3 4C 08 25			JMP	SPCDNE		; Done.
   575
   576 					;; Do the Special, get all IOCB params, push onto stack
   577 					
   578 24C6 A5 21		SPDO:	LDA	ZICDNO		; Unit #
   579 24C8 8D 0A 25			STA	SPEDCB+1
   580 24CB A5 22			LDA	ZICCOM		; Command
   581 24CD 8D 0B 25			STA	SPEDCB+2
   582 24D0 AD B8 25			LDA	INQDS		; Result of Inquiry
   583 24D3 8D 0C 25			STA	SPEDCB+3
   584 24D6 A5 24			LDA	ZICBAL		; Ptr to passed in devicespec
   585 24D8 8D 0D 25			STA	SPEDCB+4
   586 24DB A5 25			LDA	ZICBAH		; ssh-add ~/.ssh/id_rsa
   587 24DD 8D 0E 25			STA	SPEDCB+5
   588 24E0 A9 00			LDA #$00
   589 24E2 8D 11 25			STA SPEDCB+8
   590 24E5 A9 01			LDA #$01
   591 24E7 8D 12 25			STA SPEDCB+9
   592 24EA A5 2A			LDA	ZICAX1		; Aux1
   593 24EC 8D 13 25			STA	SPEDCB+10
   594 24EF A5 2B			LDA	ZICAX2		; Aux2
   595 24F1 8D 14 25			STA	SPEDCB+11
   596
   597 24F4 A9 09			LDA	#<SPEDCB
   598 24F6 A0 25			LDY	#>SPEDCB
   599 24F8 20 6C 23			JSR	DOSIOV
   600
   601 					;; Get error and return extended if needed.
   602
   603 24FB AC 03 03			LDY	DSTATS		; Get DSTATS
   604 24FE C0 90			CPY	#144		; Is it 144?
   605 2500 D0 06			BNE	SPCDNE		; Nope, just return it.
   606
   607 2502 20 20 22			JSR	POLL		; Get status, for error
   608 2505 AC ED 02			LDY	DVSTAT+3	; Get extended error.
   609
   610 					
   611 2508 60			SPCDNE:	RTS
   612
   613 2509 71			SPEDCB .BYTE      DEVIDN  ; DDEVIC
   614 250A FF			       .BYTE      $FF     ; DUNIT
   615 250B AD 03 03			LDA	DSTATS
   616 250E C9 90			CMP	#144
   617 2510 F0 5C			BEQ	BLDON
   618 2512 FF			       .BYTE      $FF     ; DCOMND ; inq
   619 2513 40			       .BYTE      DSREAD     ; DSTATS
   620 2514 B8 25		       .WORD      INQDS    ; DBUFL
   621 2516 1F			       .BYTE      $1F     ; DTIMLO
   622 2517 00			       .BYTE      $00     ; DRESVD
   623 2518 01			       .BYTE      $01     ; DBYTL
   624 2519 00			       .BYTE      $00     ; DBYTH
   625 251A FF			       .BYTE      $FF     ; DAUX1
   626 251B FF			       .BYTE      $FF     ; DAUX2	
   627
   628 					; Binary Load (Command 40)
   629 251C 20 85 23		BLOAD:	JSR	OPEN
   630
   631 					; Read header (expect FFFF)
   632 251F 20 1C 22		GETFIL: JSR	GDIDX
   633 2522 A9 02			LDA	#$02
   634 2524 9D AC 25			STA	RLEN,X
   635 2527 20 C1 22			JSR	READ
   636
   637 					; Check if FFFF
   638 252A 20 A2 25			JSR	CHKFF
   639
   640 					; Read start/end addresses
   641 252D 20 1C 22			JSR	GDIDX
   642 2530 A9 04		       	LDA	#$04
   643 2532 9D AC 25			STA	RLEN,X
   644 2535 20 C1 22			JSR	READ
   645
   646 					; Save start/end addresses
   647 2538 20 71 25			JSR 	STRAD
   648 253B 20 7D 25			JSR	BUFLEN
   649
   650 					; Inject start addr into DCB DBUF
   651 253E AD C3 26			LDA	STL
   652 2541 8D F2 22			STA	READCB+4
   653 2544 AD C4 26			LDA	STH
   654 2547 8D F3 22			STA	READCB+5 	 
   655
   656 					; Inject payload size into DCB DBYT, AUX
   657 254A AD C7 26			LDA	BLL		
   658 254D 8D F6 22			STA	READCB+8
   659 2550 8D F8 22			STA	READCB+10
   660 2553 AD C8 26			LDA	BLH
   661 2556 8D F7 22			STA	READCB+9
   662 2559 8D F9 22			STA	READCB+11
   663
   664 					;---------------
   665 255C A9 40			LDA	#$40
   666 255E 8D C6 02			STA	COLOR2
   667 					;---------------
   668 2561 20 D9 22			JSR	RENTR		; Use entry point into READ
   669 					
   670 					; Restore RBUF
   671 2564 A9 C1			LDA	#<RBUF
   672 2566 8D F2 22			STA	READCB+4
   673 2569 A9 25			LDA	#>RBUF
   674 256B 8D F3 22			STA	READCB+5
   675
   676 					;LDA 	#$00
   677 					;BEQ 	GETFIL		; Force loop
   678
   679 256E A0 01		BLDON:	LDY	#$01		; Return success for now
   680 2570 60				RTS
   681
   682 					; Store start/end addresses
   683 2571 A2 03		STRAD:	LDX	#$03		; Iterate 4 times
   684 2573 BD C1 25		STRLP:	LDA	RBUF,X
   685 2576 9D C3 26			STA	STL,X
   686 2579 CA				DEX
   687 257A D0 F7			BNE	STRLP
   688 257C 60				RTS
   689 					
   690 					; Calculate binary payload size
   691 257D AD C5 26		BUFLEN: LDA	ENL
   692 2580 38			        SEC
   693 2581 ED C3 26		        SBC	STL
   694 2584 8D C7 26		        STA	BLL             ; LOW BYTE
   695 2587 AD C6 26		        LDA	ENH
   696 258A ED C4 26		        SBC	STH
   697 258D 8D C8 26		        STA	BLH             ; HIGH BYTE
   698 2590 18			        CLC                     ; NOW ADD ONE
   699 2591 AD C7 26		        LDA	BLL
   700 2594 69 01		        ADC	#1
   701 2596 8D C7 26		        STA	BLL
   702 2599 AD C8 26		        LDA	BLH
   703 259C 69 00		        ADC	#0              ; TAKE CARE OF ANY CARRY
   704 259E 8D C8 26		        STA	BLH
   705 25A1 60			        RTS
   706 					
   707 					; Confirm header begins with FFFF
   708 25A2 EE C1 25		CHKFF:	INC	RBUF		; If FF then now 00
   709 25A5 D0 03			BNE	CHDON		; Quit if it wasnt FF
   710 25A7 EE C2 25			INC	RBUF+1		; Again
   711 25AA 60			CHDON:	RTS
   712
   713 					
   714 					;; End of Handler
   715
   716 				;;; VARIABLES ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   717
   718 = 25AB			TRIP	.ds	1		; Interrupt Tripped?
   719 = 25AC			RLEN	.ds	MAXDEV		; RXD Len
   720 = 25B0			ROFF	.ds	MAXDEV		; RXD offset cursor
   721 = 25B4			TOFF	.ds	MAXDEV		; TXD offset cursor
   722 = 25B8			INQDS	.ds	1		; DSTATS to return in inquiry
   723 = 25B9			DVS2	.ds	MAXDEV		; DVSTAT+2 SAVE
   724 = 25BD			DVS3	.ds	MAXDEV		; DVSTAT+3 SAVE
   725
   726 = 25C1			RBUF	.ds	128		; RXD buffer
   727 = 2641			TBUF	.ds	128		; TXD buffer
   728 					
   729 				;;; BINARY LOADER TEMP VARIABLES ;;;;;;;;;;;;;;;;
   730
   731 = 26C1			SL	.ds     1
   732 = 26C2			SH	.ds     1
   733 = 26C3			STL	.ds     1
   734 = 26C4			STH	.ds     1
   735 = 26C5			ENL	.ds     1
   736 = 26C6			ENH	.ds     1
   737 = 26C7			BLL 	.ds     1
   738 = 26C8			BLH 	.ds     1
   739
   740 = 26C9			HANDLEREND	= *
