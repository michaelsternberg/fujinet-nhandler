    99 				;;; RESET HANDLER ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   100
   101 2201			RESET:	
   102 2201 20 FF FF			JSR	$FFFF		; Modified for original DOSINI
   103 2204 A9 FF			LDA	#$FF		; Driver end LO
   104 2206 8D E7 02			STA 	MEMLO
   105 2209 A9 FF			LDA	#$FF		; Driver end HI
   106 220B 8D E8 02			STA	MEMLO+1
   107 220E 20 2B 23			JSR	IHTBS		; Insert into HATABS
   108 2211 20 AB 22			JSR	CLALL
   109 2214 60				RTS
   110 					
   111 				;;; END RESET HANDLER ;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   112
   113 				;;; INTERRUPT HANDLER ;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   114
   115 2215 A9 01		INTR:	LDA	#$01		; set trip to 1
   116 2217 8D AB 25			STA	TRIP
   117 221A 68				PLA
   118 221B 40				RTI
   119 					
   120 				;;; END INTERRUPT HANDLER ;;;;;;;;;;;;;;;;;;;;;;;;
