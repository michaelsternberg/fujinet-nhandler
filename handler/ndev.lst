   122 				;;; SUBROUTINES ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   123
   124 					;; GET IOCB UNIT # INTO X
   125 					
   126 221C A6 21		GDIDX:	LDX	ZICDNO		; CURRENT IOCB UNIT #
   127 221E CA				DEX			; -1
   128 221F 60				RTS
   129
   130 					;; Poll for Status
   131
   132 2220 A5 21		POLL:	LDA	ZICDNO		; Get Unit #
   133 2222 8D 2E 22			STA	POLDCB+1	; Put into Table
   134 2225 A9 2D			LDA	#<POLDCB	; Set up STATUS POLL DCB table
   135 2227 A0 22			LDY	#>POLDCB
   136 2229 20 6C 23			JSR	DOSIOV		; And do SIOV
   137 					
   138 222C 60				RTS
   139
   140 222D 71			POLDCB:	.BYTE      DEVIDN  ; DDEVIC
   141 222E FF				.BYTE      $FF     ; DUNIT
   142 222F 53				.BYTE      'S'     ; DCOMND
   143 2230 40				.BYTE      DSREAD     ; DSTATS
   144 2231 EA 02			.WORD	   DVSTAT  ; DBUF
   145 2233 1F				.BYTE      $1F     ; DTIMLO
   146 2234 00				.BYTE      $00     ; DRESVD
   147 2235 04 00			.WORD	   4	   ; 4 bytes
   148 2237 00				.BYTE      $00     ; DAUX1
   149 2238 00				.BYTE      $00     ; DAUX2
   150
   151 					;; Save DVSTAT values
   152
   153 2239 20 1C 22		SVSTAT: JSR	GDIDX	   	; Get Unit into X
   154 223C 20 96 22			JSR	CAPRX		; Cap RX values
   155 223F AD EA 02			LDA	DVSTAT		; Get RX bytes waiting
   156 2242 9D AC 25			STA	RLEN,X		; Save RX bytes waiting
   157 2245 AD EC 02			LDA	DVSTAT+2	; Get Server Client connected/disconnected?
   158 2248 9D B9 25			STA	DVS2,X		; Save 
   159 224B AD ED 02			LDA	DVSTAT+3	; Get last error
   160 224E 9D BD 25			STA	DVS3,X		; Save
   161 2251 60				RTS
   162 					
   163 					;; Enable PROCEED interrupt
   164
   165 2252 AD 02 D3		ENPRCD:	LDA	PACTL		; Get PACTL register
   166 2255 09 01			ORA	#$01		; Enable PROCEED
   167 2257 8D 02 D3			STA	PACTL		; Store it back
   168 225A 60				RTS
   169
   170 					;; Disable PROCEED interrupt
   171 					
   172 225B AD 02 D3		DIPRCD:	LDA	PACTL		; Get PACTL register
   173 225E 29 FE			AND	#$FE		; Disable PROCEED
   174 2260 8D 02 D3			STA	PACTL		; store it back.
   175 2263 60				RTS
   176
   177 					;; Flush TX Buffer out
   178 					
   179 2264 20 1C 22		FLUSH:	JSR	GDIDX		; UNIT NUMBER into X
   180 2267 A5 21			LDA	ZICDNO		; IOCB UNIT #
   181 2269 8D 8B 22			STA	FLUDCB+1	; Put into table.
   182 226C BD B4 25			LDA	TOFF,X		; get Transmit offset (# of bytes to send)
   183 226F F0 18			BEQ	FLDONE		; Don't do anything if TX cursor is at 0.
   184 2271 8D 92 22			STA	FLUDCB+8	; Put into Table (Len and Aux)
   185 2274 8D 94 22			STA	FLUDCB+10
   186 2277 A9 8A			LDA	#<FLUDCB	; Copy Table to DCB
   187 2279 A0 22			LDY	#>FLUDCB
   188 227B 20 6C 23			JSR	DOSIOV		; And call SIOV
   189 227E 20 1C 22			JSR	GDIDX		; Get Unit into X
   190 2281 A9 00			LDA	#$00		; Clear TOFF
   191 2283 9D B4 25			STA	TOFF,X
   192 2286 AC 03 03			LDY	DSTATS
   193 2289 60			FLDONE:	RTS			; Done, LDY has DSTATS
   194
   195 228A 71			FLUDCB:	.BYTE      DEVIDN  	; DDEVIC
   196 228B FF				.BYTE      $FF     	; DUNIT
   197 228C 57				.BYTE      'W'     	; DCOMND
   198 228D 80				.BYTE      DSWRIT     	; DSTATS
   199 228E 41 26			.WORD      TBUF    	; DBUFL
   200 2290 1F				.BYTE      $1F     	; DTIMLO
   201 2291 00				.BYTE      $00     	; DRESVD
   202 2292 FF				.BYTE      $FF     	; DBYTL
   203 2293 00				.BYTE      $00     	; DBYTH
   204 2294 FF				.BYTE      $FF     	; DAUX1
   205 2295 00				.BYTE      $00     	; DAUX2
   206
   207 					;; Cap RX to 127 bytes (temporary routine)
   208
   209 2296 AD EB 02		CAPRX:	LDA	DVSTAT+1	; Get hi-byte
   210 2299 D0 05			BNE	CAPADJ		; Adjust if > 256 bytes
   211 229B AD EA 02			LDA	DVSTAT		; Get lo-byte
   212 229E 10 0A			BPL	CAPDON		; Exit if < 127 bytes
   213 22A0 A9 7F		CAPADJ:	LDA	#$7F		; 127 bytes
   214 22A2 8D EA 02			STA	DVSTAT		; into DVSTAT/DVSTAT+1
   215 22A5 A9 00			LDA	#$00
   216 22A7 8D EB 02			STA	DVSTAT+1
   217 22AA 60			CAPDON:	RTS			; Done
   218
   219 					;; Close all IOCBs
   220
   221 22AB A9 04		CLALL:	LDA	#MAXDEV		; Close all 4 N: devices
   222 22AD 8D AB 25			STA	TRIP		; Temporarily use trip
   223 22B0 AD AB 25		CLLP:	LDA	TRIP		; Get
   224 22B3 85 21			STA	ZICDNO		; Store into unit #
   225 22B5 20 C2 23			JSR	CLOSE		; Close Nx:
   226 22B8 CE AB 25			DEC	TRIP		; Decrement
   227 22BB AD AB 25			LDA	TRIP		; Get it
   228 22BE D0 F0			BNE	CLLP		; Loop until done.
   229 22C0 60				RTS	
   230
   231 					;; Do read from ZIOCB unit
   232
   233 22C1 20 1C 22		READ:	JSR	GDIDX	  	; unit into X
   234 22C4 A9 00			LDA	#$00		; Set 0 into
   235 22C6 9D B0 25			STA	ROFF,X		; RXD cursor.
   236 22C9 A5 21			LDA	ZICDNO		; Get Unit #
   237 22CB 8D EF 22			STA	READCB+1	; Put into Read DCB table
   238 22CE AD AC 25			LDA	RLEN		; Get RLEN (from status)
   239 22D1 F0 1A			BEQ	RDONE		; If RLEN=0 then abort read.
   240 22D3 8D F6 22			STA	READCB+8	; Store in DBYTL
   241 22D6 8D F8 22			STA	READCB+10	; Store in DAUX1
   242 22D9 A9 EE		RENTR:	LDA	#<READCB	; Set up Read DCB
   243 22DB A0 22			LDY	#>READCB	; ...
   244 22DD 20 6C 23			JSR	DOSIOV		; Do SIO call
   245 22E0 AC 03 03			LDY	DSTATS		; Get DSTATS for error
   246 22E3 C0 90			CPY	#144		; Is it 144?
   247 22E5 D0 06			BNE	RDONE		; No, simply return DSTATS in Y
   248 22E7 20 20 22			JSR	POLL		; Otherwise, do a poll to get extended error
   249 22EA AC ED 02			LDY	DVSTAT+3	; And return it in Y.
   250 22ED 60			RDONE:	RTS			; Done.
   251
   252 22EE 71			READCB .BYTE     DEVIDN  	; DDEVIC
   253 22EF FF			       .BYTE     $FF     	; DUNIT
   254 22F0 52			       .BYTE     'R'     	; DCOMND
   255 22F1 40			       .BYTE     DSREAD     	; DSTATS
   256 22F2 C1 25		       .WORD	 RBUF	 	; DBUF
   257 22F4 1F			       .BYTE     $1F     	; DTIMLO
   258 22F5 00			       .BYTE     $00     	; DRESVD
   259 22F6 FF			       .BYTE     $FF     	; DBYTL
   260 22F7 00			       .BYTE     $00     	; DBYTH
   261 22F8 FF			       .BYTE     $FF     	; DAUX1
   262 22F9 00			       .BYTE     $00     	; DAUX2
   263 					
   264 				;;; END SUBROUTINES ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
